# -----------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
.eggs/

# -----------------------------------------------------------------------
# Virtual Environments — NEVER commit these (huge, machine-specific)
# -----------------------------------------------------------------------
venv/
env/
.venv/
.env/
ENV/

# -----------------------------------------------------------------------
# Environment / Secrets — NEVER commit real credentials
# -----------------------------------------------------------------------
# .env contains AWS keys and Redshift passwords — must stay local
.env

# .env.example is safe to commit (no real values, just template)
# !backend/.env.example  ← already included (not ignored)

# -----------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------
# LangGraph / LangChain cache
# -----------------------------------------------------------------------
.langchain/
.langgraph/

# -----------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------
# Node.js / Frontend (for when we build the React frontend)
# -----------------------------------------------------------------------
node_modules/
frontend/dist/
frontend/build/
frontend/.env.local

# -----------------------------------------------------------------------
# Jupyter (if any exploratory notebooks are added)
# -----------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
